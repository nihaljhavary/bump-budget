# Supabase — get these from your Supabase project settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Anthropic — server-side only (Netlify env vars, never commit)
ANTHROPIC_API_KEY=sk-ant-...

# Paystack — public key safe to expose via VITE_, secret key server-side only
VITE_PAYSTACK_PUBLIC_KEY=pk_live_...
PAYSTACK_SECRET_KEY=sk_live_...

# Supabase service role — server-side only (Netlify env vars, NEVER commit)
# Get from Supabase project settings > API > service_role key
SUPABASE_SERVICE_KEY=eyJ...

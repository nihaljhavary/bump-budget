# bump. — Netlify cache control headers
# ─────────────────────────────────────────────────────────────────────────────
# index.html must NEVER be cached. Browsers must always re-fetch it so they
# pick up the new hashed JS/CSS filenames after each deploy.
# Hashed assets (/assets/*) are safe to cache forever — Vite content-hashes
# the filenames, so stale references are automatically invalidated on deploy.

/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

/*
  Cache-Control: no-cache
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://js.paystack.co; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.anthropic.com https://api.paystack.co https://*.paystack.co; frame-src https://js.paystack.co https://paystack.com; object-src 'none'; base-uri 'self'

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/version.json
  Cache-Control: no-cache, no-store, must-revalidate
